#!/usr/bin/env sh
# Block commits that contain CRLF in staged text-like files.

set -eu

failed=0

tmp_file="$(mktemp)"
trap 'rm -f "$tmp_file"' EXIT INT TERM
git diff --cached --name-only --diff-filter=ACM > "$tmp_file"

while IFS= read -r file; do
  case "$file" in
    *.go|*.md|*.txt|*.json|*.yml|*.yaml|*.ts|*.tsx|*.js|*.jsx|*.css|*.html|*.py|*.ps1|*.nsh|*.plist|*.manifest|*.mod|*.sum)
      if git show ":$file" | LC_ALL=C grep -q "$(printf '\r')"; then
        echo "CRLF detected in staged file: $file"
        failed=1
      fi
      ;;
  esac
done < "$tmp_file"

if [ "$failed" -ne 0 ]; then
  echo "Commit blocked: convert CRLF to LF and restage files."
  exit 1
fi

exit 0
